{
  "name": "@softwareventures/eslint-config",
  "version": "0.0.0-development",
  "description": "Standard eslint configuration for Software Ventures Limited",
  "keywords": [
    "TypeScript",
    "eslint",
    "eslint-config"
  ],
  "author": "Daniel Cassidy <mail@danielcassidy.me.uk>",
  "homepage": "https://github.com/softwareventures/eslint-config",
  "bugs": "https://github.com/softwareventures/eslint-config",
  "repository": "github:softwareventures/eslint-config",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "commit": "cz",
    "fix": "tsc && eslint --fix . && prettier --write .",
    "postinstall": "husky",
    "lint": "tsc && eslint . && prettier --check .",
    "prepack": "tsc",
    "test": "echo No tests yet"
  },
  "sideEffects": false,
  "exports": {
    ".": "./index.js"
  },
  "engines": {
    "node": "^20 || ^22 || ^24 || >=25"
  },
  "dependencies": {
    "@softwareventures/nullable": "^3.2.0",
    "tslib": "^2.3.1"
  },
  "peerDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-jsdoc": "^62.0.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-sonarjs": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/cz-commitlint": "20.5.1",
    "@eslint/js": "9.39.4",
    "@softwareventures/precise-commits": "4.0.25",
    "@softwareventures/prettier-config": "4.0.0",
    "@softwareventures/tsconfig": "8.1.2",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "commitizen": "4.3.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "eslint-plugin-sonarjs": "4.0.3",
    "husky": "9.1.7",
    "inquirer": "13.4.2",
    "prettier": "3.8.3",
    "typescript": "5.9.3"
  },
  "eslintConfig": {
    "root": true,
    "extends": "."
  },
  "prettier": "@softwareventures/prettier-config",
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "release": {
    "extends": "@softwareventures/semantic-release-config"
  },
  "packageManager": "yarn@4.14.1"
}
